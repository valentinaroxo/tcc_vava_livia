extends layout

block content

  h1 Aluno: #{author.name}
  p #{author.lifespan}

  div(style='margin-left:20px;margin-top:20px')

    h2(style='font-size: 1.5rem;') Esportes praticados
    if author_books.length
      dl
        each book in author_books
          dt
            a(href=book.url) #{book.title}
          dd #{book.summary}
    else
      p Este aluno não está inscrito em esportes.

  hr
  p
    a(href=author.url+'/delete') Excluir aluno
  p
    a(href=author.url+'/update') Editar aluno
