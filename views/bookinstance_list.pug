extends layout

block content
  - const statusLabels = {Available:'Disponível', Maintenance:'Manutenção', Loaned:'Emprestado', Reserved:'Reservado', Scheduled:'Agendado', Completed:'Concluído', Cancelled:'Cancelado'}

  h1= title

  if bookinstance_list.length
    ul
      each val in bookinstance_list
        li
          a(href=val.url) #{val.book.title} : #{val.imprint} -&nbsp;
          if val.status=='Available'
            span.text-success #{statusLabels[val.status] || val.status}
          else if val.status=='Maintenance'
            span.text-danger #{statusLabels[val.status] || val.status}
          else
            span.text-warning #{statusLabels[val.status] || val.status}
          if val.status!='Available'
            span  (Data: #{val.due_back_formatted})

  else
    p Não há cronogramas/agendamentos.
